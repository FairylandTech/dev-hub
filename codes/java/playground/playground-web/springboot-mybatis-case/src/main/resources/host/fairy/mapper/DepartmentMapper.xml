<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="host.fairy.mapper.DepartmentMapper">
    <!--@Table department-->

    <resultMap id="BaseResultMap" type="host.fairy.entity.DepartmentEntity" autoMapping="true">
        <id property="id" column="id" jdbcType="INTEGER"/>
        <result property="name" column="name" jdbcType="VARCHAR"/>
        <result property="createdTime" column="created_time" jdbcType="TIMESTAMP"/>
        <result property="updatedTime" column="updated_time" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="QueryAllFields">
        select id, name, created_time, updated_time
        from department
    </sql>

    <select id="selectAll" resultMap="BaseResultMap">
        <include refid="QueryAllFields"/>;
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        <include refid="QueryAllFields"/>
        where id = #{id};
    </select>

    <select id="selectByName" resultMap="BaseResultMap">
        <include refid="QueryAllFields"/>
        where name = #{name};
    </select>

    <insert id="insert">
        insert department(name, created_time, updated_time)
        values (#{name}, #{createdTime}, #{updatedTime});
    </insert>

    <delete id="delete">
        delete from department where id = #{id};
    </delete>

    <select id="selectMaxIndex" resultType="integer">
        select max(id)
        from department;
    </select>

    <update id="updateById">
        update department
        <set>
            <if test="name != null and name != ''">
                name = #{name},
            </if>
            <if test="updatedTime != null">
                updated_time = #{updatedTime}
            </if>
        </set>
        where id = #{id};
    </update>
</mapper>
